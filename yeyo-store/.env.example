# =====================================================================
# .env.example - Variables de ejemplo para Docker
# COPIAR A .env.docker PARA DESARROLLO LOCAL
# NUNCA commitear .env real a git
# =====================================================================

# =====================================================================
# DATABASE (Local Development - PostgreSQL en Docker)
# Para producción en Supabase, reemplazar con URL real
# =====================================================================
DB_USER=yeyo_user
DB_PASSWORD=secure_password_123
DB_HOST=postgres
DB_PORT=5432
DB_NAME=yeyo_store
DATABASE_URL=postgresql://yeyo_user:secure_password_123@postgres:5432/yeyo_store

# =====================================================================
# JWT & AUTENTICACIÓN
# CAMBIAR SECRET_KEY en producción
# =====================================================================
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =====================================================================
# ENVIRONMENT
# Valores: development, production, testing
# =====================================================================
ENVIRONMENT=development
DEBUG=true

# =====================================================================
# CORS - Dominios permitidos
# En producción: https://yourdomain.com,https://www.yourdomain.com
# =====================================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,http://frontend

# =====================================================================
# FRONTEND - Variables de Vite
# =====================================================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=YeYo Store

# =====================================================================
# SUPABASE (Para producción - Base de datos real)
# Reemplazar con credenciales reales cuando despleguemos
# =====================================================================
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_KEY=xxxxx
